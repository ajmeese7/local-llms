[Unit]
Description=vLLM OpenAI-compatible server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ajmeese7
Group=ajmeese7
WorkingDirectory=/home/ajmeese7
Environment=HF_HOME=/home/ajmeese7/.cache/huggingface
Environment=PATH=/home/ajmeese7/.venvs/vllm/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/lib/wsl/lib
Environment=LD_LIBRARY_PATH=/usr/lib/wsl/lib
ExecStart=/etc/vllm/vllm-launcher.sh
Restart=always
RestartSec=10
TimeoutStartSec=300
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
